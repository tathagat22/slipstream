# Slipstream runs fully in-memory with ZERO config for local dev.
# For a real *shared* cache in production, add an Upstash Redis (one click on
# the Vercel Marketplace) — the cache + global counter then persist and are
# shared across every serverless invocation and every agent on Earth.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: enables JS rendering for SPAs. When set, Slipstream detects
# under-rendered single-page apps and renders them via Firecrawl instead of
# returning partial static HTML. Without it, SPAs are served best-effort and
# labeled "content may be partial".
FIRECRAWL_API_KEY=
