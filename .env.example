# Slipstream runs fully in-memory with ZERO config for local dev.
# For a real *shared* cache in production, add an Upstash Redis (one click on
# the Vercel Marketplace) — the cache + global counter then persist and are
# shared across every serverless invocation and every agent on Earth.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
